# If you want to develop for the mobile shell, you can run that part as an npm
# server and set the URL here. It allows for hot-reloading.
#CAP_SERVER_URL=
DATABASE_URL="postgres://root:STRONG_RANDOM_SECRET@localhost:5432/local"
POSTGRES_USER=root
POSTGRES_PASSWORD=STRONG_RANDOM_SECRET
POSTGRES_DB=local
APP_HOST=localhost
SESSION_EXPIRY=7d
TZ=Europe/Berlin

COMPOSE_BAKE=true